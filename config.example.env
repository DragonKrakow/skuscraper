# Allegro OAuth2 / API configuration (Poland scraper)
ALLEGRO_CLIENT_ID=your_client_id_here
ALLEGRO_CLIENT_SECRET=your_client_secret_here
# Optional: provide access token manually for scaffolded listing requests
ALLEGRO_ACCESS_TOKEN=

# Optional source toggles (true/false)
ENABLE_TROVAPREZZI=true
ENABLE_AMAZON_IT=true
ENABLE_EBAY_IT=true
ENABLE_ALLEGRO=true
ENABLE_CENEO=true

# Optional per-source request settings (timeout/retry/backoff/rate-limit/proxy)
AMAZON_IT_TIMEOUT=12
AMAZON_IT_RETRIES=2
AMAZON_IT_BACKOFF_SECONDS=1.0
AMAZON_IT_RATE_LIMIT_SECONDS=1.5
AMAZON_IT_PROXY=

EBAY_IT_TIMEOUT=12
EBAY_IT_RETRIES=2
EBAY_IT_BACKOFF_SECONDS=1.0
EBAY_IT_RATE_LIMIT_SECONDS=1.0
EBAY_IT_PROXY=
